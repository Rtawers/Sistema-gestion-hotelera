# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=genera-una-con-django.core.management.utils.get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL en Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=hoteleria_db
DB_USER=hoteleria_user
DB_PASSWORD=cambia-esta-contrasena
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7